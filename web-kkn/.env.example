# Supabase API
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Supabase Postgres (password database project)
SUPABASE_PROJECT_PW=

# Opsional: full connection string (override auto-build dari URL + password)
# SUPABASE_DB_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres

# Supabase Storage buckets
SUPABASE_STORAGE_BUCKET_LOGBOOK=logbook
SUPABASE_STORAGE_BUCKET_FINANCE=finance

# Opsional: token QR absensi permanen (kalau kosong, generate otomatis sekali di DB)
# ABSEN_QR_SECRET=
